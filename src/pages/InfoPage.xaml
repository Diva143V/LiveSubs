<Page
    x:Class="LIveSubs.InfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="InfoPage"
    mc:Ignorable="d">

    <ScrollViewer Padding="20">
        <StackPanel Orientation="Vertical" Margin="0,0,0,10">
            <TextBlock
                Margin="0,0,0,10"
                FontSize="20"
                FontWeight="Bold"
                Text="About LiveSubs" />

            <TextBlock Margin="0,0,0,5" TextWrapping="Wrap">
                <Run Text="LiveSubs is a real-time subtitle and translation overlay powered by Windows Live Captions." />
            </TextBlock>

            <TextBlock Margin="0,10,0,3">
                <Run FontWeight="SemiBold" Text="Repository: " />
                <Hyperlink
                    NavigateUri="https://github.com/Diva143V/LiveSubs"
                    RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="https://github.com/Diva143V/LiveSubs" />
                </Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,0,0,3">
                <Run FontWeight="SemiBold" Text="Wiki / documentation: " />
                <Hyperlink
                    NavigateUri="https://github.com/Diva143V/LiveSubs/wiki"
                    RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="https://github.com/Diva143V/LiveSubs/wiki" />
                </Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,0,0,3">
                <Run FontWeight="SemiBold" Text="Releases: " />
                <Hyperlink
                    NavigateUri="https://github.com/Diva143V/LiveSubs/releases"
                    RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="https://github.com/Diva143V/LiveSubs/releases" />
                </Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,10,0,3">
                <Run FontWeight="SemiBold" Text="Maintainer: " />
                <Hyperlink
                    NavigateUri="https://github.com/Diva143V"
                    RequestNavigate="Hyperlink_RequestNavigate">
                    <Run Text="@Diva143V" />
                </Hyperlink>
            </TextBlock>

            <TextBlock Margin="0,0,0,3">
                <Run FontWeight="SemiBold" Text="License: " />
                <Run Text="MIT (see LICENSE file in the repository)." />
            </TextBlock>

            <TextBlock Margin="0,10,0,0" TextWrapping="Wrap">
                <Run Text="If you encounter issues or have feature requests, please open an issue on GitHub or start a discussion in the LiveSubs repository." />
            </TextBlock>
        </StackPanel>
    </ScrollViewer>
</Page>